{
  "name": "react-capacitor",
  "description": "React PWA + Capacitor (Android/iOS), Vite, Vitest, Tailwind, shadcn/ui",
  "variables": {
    "TEST_CMD_PRIMARY": "bunx vitest run",
    "TEST_CMD_SECONDARY": "",
    "TEST_CI_CMD": "bunx vitest run --reporter=verbose",
    "TYPECHECK_CMD": "bunx tsc --noEmit",
    "FORMAT_CMD": "bunx prettier --write",
    "FORMAT_EXTENSIONS": "*.ts|*.tsx|*.js|*.jsx|*.json|*.css|*.md|*.html|*.yaml|*.yml",
    "COVERAGE_THRESHOLD": "70",
    "SCOPES": "app, ui, lib, store, hooks, db, sync, crypto",
    "HAS_AGENTS": true,
    "AGENT_LIST": ["ui-dev", "data-dev"],
    "TYPES_FILE": "src/types/index.ts",
    "COMPONENTS_DIR": "src/components/",
    "COMPONENTS_GLOB": "src/components/**/*.tsx",
    "DATA_FILE": "src/lib/db.ts",
    "TEST_DIR": "src/**/__tests__/",
    "TEST_GLOB": "src/**/__tests__/*.test.{ts,tsx}",
    "PACKAGE_MANAGER": "bun",
    "LINT_STAGED": {
      "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
      "*.{json,css,md,html,yaml,yml}": ["prettier --write"]
    },
    "PACKAGE_SCRIPTS": {
      "test": "vitest run",
      "test:watch": "vitest",
      "test:coverage": "vitest run --coverage",
      "test:ci": "vitest run --reporter=verbose",
      "typecheck": "tsc --noEmit",
      "prepare": "husky"
    }
  }
}
