{
  "name": "nextjs",
  "description": "Next.js 15 + App Router + Vitest + pnpm",
  "variables": {
    "TEST_CMD_PRIMARY": "pnpm vitest run",
    "TEST_CMD_SECONDARY": "",
    "TEST_CI_CMD": "pnpm vitest run",
    "TYPECHECK_CMD": "pnpm tsc --noEmit",
    "FORMAT_CMD": "pnpm prettier --write",
    "FORMAT_EXTENSIONS": "*.ts|*.tsx|*.js|*.jsx|*.json|*.css|*.md|*.html|*.yaml|*.yml",
    "COVERAGE_THRESHOLD": "70",
    "SCOPES": "app, api, components, lib, auth, db",
    "HAS_AGENTS": false,
    "TYPES_FILE": "src/lib/types.ts",
    "COMPONENTS_DIR": "src/components/",
    "COMPONENTS_GLOB": "src/components/**/*.tsx",
    "DATA_FILE": "src/server/db/schema.ts",
    "TEST_DIR": "src/**/__tests__/",
    "TEST_GLOB": "src/**/__tests__/*.test.{ts,tsx}",
    "PACKAGE_MANAGER": "pnpm",
    "LINT_STAGED": {
      "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
      "*.{json,css,md,html,yaml,yml}": ["prettier --write"]
    },
    "PACKAGE_SCRIPTS": {
      "test": "vitest run",
      "test:watch": "vitest",
      "test:coverage": "vitest run --coverage",
      "test:ci": "vitest run",
      "typecheck": "tsc --noEmit",
      "prepare": "husky"
    }
  }
}
