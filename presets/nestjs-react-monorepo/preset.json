{
  "name": "nestjs-react-monorepo",
  "description": "NestJS 11 API + React 18 + Vite, npm workspaces monorepo",
  "variables": {
    "TEST_CMD_PRIMARY": "cd apps/web && npx vitest run",
    "TEST_CMD_SECONDARY": "cd apps/api && npx jest",
    "TEST_CI_CMD": "npm run test:run --workspace=apps/web && npm run test --workspace=apps/api",
    "TYPECHECK_CMD": "npx tsc --build --noEmit",
    "FORMAT_CMD": "npx prettier --write",
    "FORMAT_EXTENSIONS": "*.ts|*.tsx|*.js|*.jsx|*.json|*.css|*.md|*.html|*.yaml|*.yml",
    "COVERAGE_THRESHOLD": "70",
    "SCOPES": "api, web, worker, shared, ui, prisma, infra, ci",
    "HAS_AGENTS": true,
    "AGENT_LIST": ["backend-dev", "frontend-dev"],
    "CODEGEN_CMD": "npm run codegen",
    "TYPES_FILE": "packages/shared/src/types/index.ts",
    "COMPONENTS_DIR": "apps/web/src/components/",
    "COMPONENTS_GLOB": "apps/web/src/components/**/*.tsx",
    "DATA_FILE": "packages/shared/src/index.ts",
    "TEST_DIR": "apps/web/src/**/__tests__/",
    "TEST_GLOB": "apps/**/__tests__/*.test.{ts,tsx}",
    "PACKAGE_MANAGER": "npm",
    "LINT_STAGED": {
      "apps/web/**/*.{ts,tsx}": ["prettier --write"],
      "apps/api/**/*.{ts,tsx}": ["prettier --write"],
      "packages/**/*.{ts,tsx}": ["prettier --write"],
      "*.{json,css,md,html,yaml,yml}": ["prettier --write"]
    },
    "PACKAGE_SCRIPTS": {
      "test:ci": "npm run test:run --workspace=apps/web && npm run test --workspace=apps/api",
      "prepare": "husky"
    }
  }
}
